-- 3. CREATE (Enroll student in a course)
-- Add a record in enrollments to enroll a student in a course.

INSERT INTO enrollments (student_id, course_id, enrolled_at)
VALUES (1, 2, CURRENT_TIMESTAMP);

-- 4. READ (All students)
-- Retrieve all records from the students table.

SELECT * FROM students;

-- 5. READ (All courses)
-- Retrieve all records from the courses table.

SELECT * FROM courses;

-- 6. READ (Students with courses)
-- Display all students and the courses they are enrolled in using JOIN.

SELECT
    s.student_id,
    s.student_name,
    c.course_id,
    c.course_name
FROM students s
JOIN enrollments e
    ON s.student_id = e.student_id
JOIN courses c
    ON e.course_id = c.course_id;

-- 7. UPDATE student
-- Update a student's name using their student_id.

UPDATE students
SET student_name = 'Alan Altman'
WHERE student_id = 3;

-- 8. UPDATE course
-- Update a course name using its course_id.

UPDATE courses
SET course_name = 'English'
WHERE course_id = 1;

-- 9. DELETE enrollment
-- Delete a specific enrollment record from the enrollments table.

DELETE FROM enrollments
WHERE student_id = 1
AND course_id = 2;

-- 10. DELETE student
-- Delete a student by student_id and observe what happens to related enrollments.

-- In SQL, tables are not automatically synchronized.
-- Everything depends on how you define your foreign key constraints

DELETE FROM students
WHERE student_id = 1;

-- Bonus Challenges
-- 11. Students without courses
-- Find all students who are not enrolled in any course.

SELECT s.student_id, s.student_name
FROM students s
LEFT JOIN enrollments e
    ON s.student_id = e.student_id
WHERE e.student_id IS NULL;

-- 12. Count courses per student
-- Show how many courses each student is enrolled in.

SELECT 
    s.student_id,
    s.student_name,
    COUNT(e.course_id) AS total_courses
FROM students s
LEFT JOIN enrollments e
    ON s.student_id = e.student_id
GROUP BY s.student_id, s.student_name;

